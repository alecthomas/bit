{
  "grammars": [
    {
      "name": "bit",
      "camelcase": "Bit",
      "scope": "source.bit",
      "path": ".",
      "file-types": ["bit"],
      "injection-regex": "^bit$",
      "highlights": ["queries/highlights.scm"],
      "injections": ["queries/injections.scm"],
      "locals": ["queries/locals.scm"]
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the bit build language",
    "authors": [
      { "name": "Alec Thomas", "email": "alec@swapoff.org" }
    ],
    "links": {
      "repository": "https://github.com/alecthomas/bit"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": true,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
