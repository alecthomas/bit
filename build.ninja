dest = build
rule gocmd
  command = go build -trimpath -buildvcs=false -ldflags="-s -w -buildid=" -o $out ./$dir
build $dest/bit: gocmd cmd/bit/main.go golang/cmd.go golang/common.go golang/generate.go
  dir = cmd/bit
rule gg-enumer-426fc95dec889c44
  command = cd $dir && enumer -type=Enum -json -text
build golang/enum_enumer.go: gg-enumer-426fc95dec889c44 golang/generate.go
  dir = golang
