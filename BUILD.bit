pre fmt = rust.fmt {}

debug = rust.exe {}

release = rust.exe {
  profile = "release"
}

image = docker.image {
  tag = "bit:latest"
  depends_on = [release]
}

# Tests
test = rust.test {}

clippy = rust.clippy {}

fmt-check = rust.fmt-check {}

integration-test = exec.test {
  depends_on = [debug]
  command  = <<-EOF
  ${debug.path} --version
  ${debug.path} --plan
  EOF
}

# Build the usual suspects
target default = [release, test, clippy, fmt-check]
