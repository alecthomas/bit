debug = rust.exe {}

release = rust.exe {
  profile = "release"
}

image = docker.image {
  tag = "bit:latest"
  after = [release]
}

# Tests
test = rust.test {}

clippy = rust.clippy {}

fmt = rust.fmt {}

integration-test = exec.test {
  depends_on = [debug]
  command  = <<-EOF
  ${debug.path} --version
  ${debug.path} --plan
  EOF
}

# Build the usual suspects
target default = [release, test, clippy, fmt]
